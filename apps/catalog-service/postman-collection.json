{
	"info": {
		"_postman_id": "c8b4dfa2-2b63-42eb-bb97-b86db11096cf",
		"name": "Catalog Service API Matrix (v2)",
		"description": "Comprehensive operational Postman suite testing suite tracking both consumer search profiles and administrative mutation operations for the high-scale read-optimized Catalog Microservice. Includes automated Azure SAS token handoffs.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Public Consumer Routes",
			"description": "High-velocity unauthenticated lookups routing clean read executions.",
			"item": [
