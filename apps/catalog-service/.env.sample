# ==============================================================================
# Catalog Service Configuration
# ==============================================================================

# Environment
NODE_ENV=development
PORT=3002

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------

# MongoDB connection string
MONGO_URI=mongodb://mongodb:27017/shopnow-catalog

# ------------------------------------------------------------------------------
# Message Broker
# ------------------------------------------------------------------------------

# RabbitMQ / AMQP endpoint used for asynchronous inventory and event processing
AMQP_URL=amqp://rabbitmq:5672

# ------------------------------------------------------------------------------
# Azure Storage
# ------------------------------------------------------------------------------

# Azure Blob Storage credentials used for file uploads and SAS token generation
AZURE_STORAGE_ACCOUNT_NAME=<STORAGE_ACCOUNT_NAME>
AZURE_STORAGE_ACCOUNT_KEY=<STORAGE_ACCOUNT_KEY>

# ------------------------------------------------------------------------------
# Authentication
# ------------------------------------------------------------------------------

# RSA public key used to verify JWT access tokens.
# Must match the public key corresponding to the private key used by the auth/user service.
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
<YOUR_RSA_PUBLIC_KEY>
-----END PUBLIC KEY-----"